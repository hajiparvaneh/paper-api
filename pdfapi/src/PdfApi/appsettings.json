{
  "App": {
    "PdfProcessing": {
      "Enabled": true
    },
    "ApiKeys": ["change-me"],
    "WkhtmlToPdf": {
      "ExecutablePath": "/usr/bin/wkhtmltopdf"
    },
    "RateLimiting": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Auth": {
      "JwtSecret": "replace-with-long-secret-change-me-123456789",
      "Issuer": "PaperAPI",
      "Audience": "PaperAPI",
      "TokenLifetimeMinutes": 43200,
      "CookieName": "paperapi_session",
      "CookieSecure": false,
      "CookieHttpOnly": true,
      "CookieSameSite": "Lax"
    },
    "TwoFactor": {
      "Issuer": "PaperAPI",
      "ChallengeMinutes": 10,
      "SetupMinutes": 15,
      "RememberDeviceDays": 30,
      "RememberDeviceCookieName": "paperapi_2fa"
    },
    "DataProtection": {
      "KeyPath": "dp-keys",
      "ApplicationName": "PaperAPI"
    },
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "ConnectionStrings": {
    "Default": "Host=postgres;Port=5432;Database=paperapi;Username=paperapi;Password=paperapi"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
